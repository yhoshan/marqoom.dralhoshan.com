  "limits": [
    [
      "وحدة العد",
      "الحضور اللفظي/النمطي بعد التطبيع، لا الحكم القطعي على الاستفادة المباشرة."
    ],
    [
      "التطبيع",
      "أزيل التشكيل ووحدت صور الألف والياء والتاء المربوطة لأغراض العد."
    ],
    [
      "التداخل",
      "بعض الألفاظ تؤدي أكثر من وظيفة، لذلك لا تجمع النسب بوصفها نسبًا نهائية من كلمات الكتاب."
    ],
    [
      "الأعلام",
      "الأسماء المفردة أو المشتركة مثل مالك وحماد تحتاج مراجعة يدوية عند النشر التفصيلي."
    ],
    [
      "الكتب",
      "المصنف لا يكثر من الإحالة إلى كتب؛ المورد الغالب هو الرواية المباشرة والنقد المقارن."
    ]
  ]
}