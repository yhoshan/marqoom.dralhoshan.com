  "limits": [
    [
      "الحد الأول",
      "العد آلي مع مراجعة منهجية للقاموس، وليس تحقيقًا يدويًا لكل موضع."
    ],
    [
      "الحد الثاني",
      "بعض الألفاظ مثل مسلم، مالك، أحمد، الحسن، القاضي، الإمام قد تكون أسماء أو أوصافًا أو ألفاظًا عامة."
    ],
    [
      "الحد الثالث",
      "الأرقام تعبر عن حضور لفظي ومنهجي لا عن استفادة مباشرة قطعية."
    ],
    [
      "الحد الرابع",
      "الملفات النصية تشمل بعض مقدمات الناشر والواجهات؛ أُبقيت ضمن النطاق لأن طلب التحليل كان لجميع الملفات."
    ],
    [
      "الحد الخامس",
      "تحتاج أعلى الموارد المؤثرة إلى مراجعة سياقية عند تحويل النتائج إلى دراسة علمية محكمة."
    ]
  ]
}