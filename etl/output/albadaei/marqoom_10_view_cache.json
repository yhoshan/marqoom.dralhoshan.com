  "limits": [
    [
      "1",
      "العد آلي تقريبي مبني على النص المستخرج من EPUB، وقد تختلف النتائج باختلاف الطبعة أو ضبط النص."
    ],
    [
      "2",
      "الألفاظ المشتركة مثل الأصل ومحمد وأحمد تحتاج مراجعة سياقية قبل استخدامها في أحكام علمية تفصيلية."
    ],
    [
      "3",
      "العدد لا يساوي عدد المسائل الفقهية ولا عدد الأدلة الفريدة، بل عدد مواضع ظهور العبارات المرصودة."
    ],
    [
      "4",
      "المؤشرات المركبة مفيدة للمقارنة الداخلية، لكنها لا تثبت وحدها رأيًا منهجيًا دون قراءة العينات."
    ],
    [
      "5",
      "تم التركيز على أعلى العبارات دلالة، ولم يُبنَ القاموس على كل كلمة في الكتاب."
    ]
  ]
}