        [
          "1",
          "معجم البلدان ليس معجم مواضع فقط، بل موسوعة تجمع الجغرافيا واللغة والتاريخ والتراجم والأدب."
        ],
        [
          "2",
          "بلغت بنية المداخل المرصودة 12740 مدخلًا وفروعًا، منها 12156 مدخلًا رئيسًا."
        ],
        [
          "3",
          "الضبط اللغوي ليس عنصرًا ثانويًا؛ فقد ظهر في آلاف العبارات مثل بفتح وبضم وبكسر وبسكون."
        ],
        [
          "4",
          "النقل والعزو هو المحور الأعلى حضورًا في القاموس المنهجي، مما يبرز طبيعة ياقوت الجامعة للموارد."
        ],
        [
          "5",
          "المداخل الطويلة الكبرى تتركز في المدن والمراكز الحضارية الكبرى: دمشق، المقدس، الإسكندرية، مكة، همذان، مصر."
        ],
        [
          "6",
          "حضور عبارات النسبة إلى المواضع يكشف أن الكتاب يصلح أيضًا لخدمة دراسات التراجم والأنساب."
        ],
        [
          "7",
          "المسافات والإحداثيات ظاهرة مستقلة، لكنها أقل من التعريف والنقل والضبط."
        ],
        [
          "8",
          "الشعر والاستشهاد الأدبي جزء من بنية الكتاب، لا مجرد تزيين عارض."
        ],
        [
          "9",
          "الفهارس اللاحقة نافعة بحثيًا لكنها لا تدخل في قياس بصمة المؤلف لئلا تشوه نسب الموارد."
        ],
        [
          "10",
          "أفضل تطوير رقمي للكتاب أن يعرض المدخل بوصفه بطاقة متعددة الطبقات: موضع، ضبط، تاريخ، تراجم، شعر، موارد."
        ]
      ]
