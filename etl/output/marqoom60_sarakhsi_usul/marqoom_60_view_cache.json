      "التطبيع اللغوي",
      "أزيلت الحركات ووحدت صور الألف والهمزة والتاء المربوطة لتقليل تشتت العد."
    ],
    [
      "الكتب المصرح بها",
      "فرقت الجداول بين عناوين عالية الثقة وبين أبواب فقهية تحتاج مراجعة."
    ],
    [
      "الأعلام",
      "استعملت قرائن للتمييز، وتبقى بعض الأسماء بحاجة إلى مراجعة يدوية."
    ],
    [
      "النسب",
      "كل نسبة محسوبة من مجموع طبقتها لا من مجموع كلمات الكتاب."
    ]
  ]
