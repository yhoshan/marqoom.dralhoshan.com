  "limits": [
    [
      "1",
      "العد آلي بعد تنظيف رؤوس الصفحات والترقيم، ويحتاج أعلى النتائج مراجعة عند التوظيف العلمي الدقيق."
    ],
    [
      "2",
      "النسب لا تحسب من كلمات الكتاب، بل من مجموع الطبقة المرصودة: مصطلحات، أعلام، مدارس، موارد."
    ],
    [
      "3",
      "الأسماء المفردة المشتركة مثل الحسن وعمر وعلي قد تحتاج مراجعة سياقية، وقد وسم بعضها بدرجة ثقة متوسطة."
    ],
    [
      "4",
      "الكتاب متن قصير؛ لذلك قد تعظم النسب الصغيرة مقارنة بالموسوعات."
    ],
    [
      "5",
      "عدم ظهور أسماء كتب كثيرة لا يعني عدم وجود مصادر خارجية للمؤلف، بل يعني أن المتن لا يصرح بها لفظيًا."
    ]
  ]
}