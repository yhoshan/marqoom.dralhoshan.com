    "executive_summary": {
      "_columns": [
        "رقم",
        "النتيجة"
      ],
      "rows": [
        [
          "1",
          "الكتاب متن عقدي سلفي موجز؛ لذلك عومل بوصفه كتاب تقرير وردّ وتحذير، لا بوصفه كتاب أسانيد أو فقه مقارن."
        ],
        [
          "2",
          "حجم المتن التحليلي يقارب 6994 كلمة، وفيه 156 فقرة مرقمة، وهو كافٍ لقراءة البصمة المصطلحية مع التحفظ على صغر الحجم."
        ],
        [
          "3",
          "أبرز محور ظاهر هو تقرير السنة والجماعة والاتباع، يقابله حضور قوي للتحذير من البدعة وأهل الأهواء."
        ],
        [
          "4",
          "تغلب صيغة الأمر التعليمي: اعلم، واعلم رحمك الله، احذر، إياك؛ مما يعطي النص طبيعة تلقينية/تربوية لا جدلية مطولة."
        ],
        [
          "5",
          "الموارد النصية المصرح بها جاءت في صورة أجناس مرجعية: القرآن، السنة، الأثر؛ ولا تظهر أسماء كتب مصنفة كثيرة داخل المتن."
        ],
        [
          "6",
          "الأعلام الحاضرون غالبهم من النبي صلى الله عليه وسلم والصحابة والأئمة الأوائل، مع حضور واضح لنقول الفضيل ومالك وأحمد ويونس."
        ],
        [
          "7",
          "النسب الواردة نسب حضور لفظي داخل الطبقة نفسها، وليست حكمًا قطعيًا على مقدار الاعتماد المباشر."
        ]
      ]
    },
